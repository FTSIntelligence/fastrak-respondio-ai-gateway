# REQUIRED: choose openai or groq
AI_PROVIDER=openai

# REQUIRED only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# REQUIRED only when AI_PROVIDER=groq (Groq hosts Llama models)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# REQUIRED: create any long random secret and use the same value
# in Respond.io's Authorization header.
GATEWAY_SECRET=

# Optional tuning. Defaults are already production-safe.
PORT=3000
REQUEST_TIMEOUT_MS=8500
MAX_OUTPUT_TOKENS=450
LOG_LEVEL=info
